NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/faultline

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# AI (Gemini) — used from Task 11 onward
GEMINI_API_KEY=

# GitHub (Contents API grounding) — used from Task 12 onward.
# Optional: unauthenticated requests work for public repos (60/hour).
# Only needed for private repos or to raise the rate limit.
GITHUB_TOKEN=

# Redis (Task 25) -- BullMQ job queue for AI enrichment. In deployment,
# points at Render's free "Key Value" (Redis-compatible) tier -- see
# DECISIONS.md's "Task 25" entry for why that over a third-party host.
# For local dev, point this at a local Redis instance
# (e.g. redis://localhost:6379) or a dev Render Key Value instance.
# Required for both the API process (enqueues jobs) and worker.js (the
# separate process that consumes them) -- see worker.js.
REDIS_URL=redis://localhost:6379

# Resend (Task 28) -- email delivery for alert notifications
# (new-group / severity-threshold triggers, see Project.alertConfig).
# Optional: alerting is opt-in per project, so a missing key only
# matters once a project actually enables a trigger -- see
# services/alertService.js. RESEND_FROM_EMAIL must be a domain
# verified with Resend; defaults to alerts@faultline.dev otherwise.
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@faultline.dev

# CORS
CLIENT_ORIGIN=http://localhost:5173