NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/faultline

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# AI (Gemini) — used from Task 11 onward
GEMINI_API_KEY=

# GitHub (Contents API grounding) — used from Task 12 onward.
# Optional: unauthenticated requests work for public repos (60/hour).
# Only needed for private repos or to raise the rate limit.
GITHUB_TOKEN=

# CORS
CLIENT_ORIGIN=http://localhost:5173